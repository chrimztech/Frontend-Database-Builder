# Public Supabase config — safe to commit (these are already in .env)
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<anon key>"
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon key>"

# ── Secrets: copy these lines into .env.local (never commit .env.local) ──────

# Service role key — from Supabase dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY="<service role key>"

# Certificate signing secret — any long random string, e.g. generated with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
CERT_SIGNING_SECRET="<random secret>"
