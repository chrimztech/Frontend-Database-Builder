# Copy to /etc/cemis/frontend.env on the server, fill in real values, then:
#   chmod 600 /etc/cemis/frontend.env
#   chown cemis:cemis /etc/cemis/frontend.env
#
# Note: VITE_API_URL is a BUILD-TIME value, not read from here — it's baked
# into the client bundle from the repo's .env file at `npm run build` time.
# This file only supplies values the running Node server reads at request time.

PORT=4000
HOST=127.0.0.1

# ── Email (Gmail SMTP / Google Workspace) — used by lib/email.server.ts ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=train@unza.ac.zm
SMTP_PASS=CHANGE_ME
SMTP_FROM=UNZA TeLS <train@unza.ac.zm>
